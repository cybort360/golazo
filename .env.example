# Canonical site URL (used for share/OG image links). e.g. https://golazo.fun
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin only
ADMIN_SECRET=

# Protects /api/cron/sync (serverless live-sync). Vercel Cron injects this as a
# Bearer token; an external pinger (cron-job.org) must send it too.
CRON_SECRET=

# Live scores: free football-data.org token (register at football-data.org).
# Drives auto-populated live scores and results. If unset, the site falls back
# to manual result entry only — nothing breaks.
WORLD_CUP_API_TOKEN=

# Telegram broadcast (optional): a bot token from @BotFather and the channel it
# posts to (e.g. @golazofun or a numeric chat id). Add the bot as a channel
# admin. If either is unset, broadcasting is silently disabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Telegram webhook secret (optional): a random string you choose. Pass it to
# setWebhook as secret_token; the /api/telegram/webhook route rejects calls
# without it. Lets /start reply with a Play button.
TELEGRAM_WEBHOOK_SECRET=

# Telegram Mini App link (optional): the t.me link to the prediction Mini App,
# e.g. https://t.me/golazo_feed_bot/predict — create it in @BotFather (/newapp)
# pointed at <site>/tg. When set, channel posts and the site show a button that
# opens the Mini App natively. Public so the website can link to it too.
NEXT_PUBLIC_TELEGRAM_APP_URL=

# Vercel KV
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Golazo Markets (devnet-only on-chain module) ────────────────────────────
# Master switch for Market Mode (the "Free Picks | Market Mode" toggle).
NEXT_PUBLIC_ENABLE_MARKET_MODE=false
# Solana cluster. Devnet only for this prototype — never mainnet.
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
# RPC endpoint. Public devnet is rate-limited; set a dedicated devnet endpoint
# (Helius/QuickNode) for any hosted deploy. Defaults to the public cluster RPC.
NEXT_PUBLIC_SOLANA_RPC=
# Devnet mock SPL escrow path (the only supported settlement asset).
NEXT_PUBLIC_ENABLE_DEVNET_SPL_ESCROW=true
# Future native-SOL settlement — placeholder, hard-disabled in this build.
NEXT_PUBLIC_ENABLE_NATIVE_SOL_SETTLEMENT=false
# Mainnet markets are never permitted in this prototype.
NEXT_PUBLIC_ENABLE_MAINNET_MARKETS=false

# Deployed program IDs + mock SPL mint (written by anchor/scripts/setup-devnet).
NEXT_PUBLIC_TXLINE_MOCK_PROGRAM=
NEXT_PUBLIC_GOLAZO_PREDICT_PROGRAM=
NEXT_PUBLIC_GOLAZO_MINT=

# Postgres (Neon/Vercel in deployed envs; local Postgres for dev). Server-only,
# Node runtime only — never imported into client components or edge routes.
DATABASE_URL=

# ── TxLINE (live data + result verification) ─────────────────────────────────
# The whole product reads football data + verified results through one seam
# (lib/txline). "mock" serves scripted World Cup 2026 fixtures (no API needed);
# set "live" once real TxLINE access is wired into RealTxlineClient.
TXLINE_MODE=mock
# Real-mode credentials (unused while TXLINE_MODE=mock). Obtain via the one-time
# access bootstrap in planning/txline.md (guest JWT -> on-chain subscribe ->
# token activate). The free tier covers World Cup 2026.
#   Host: https://txline.txodds.com (mainnet) | http://txline-dev.txodds.com (devnet)
TXLINE_API_BASE=
# Guest JWT from POST /auth/guest/start (30-day expiry — refresh before it lapses).
TXLINE_JWT=
# Activated token from POST /api/token/activate, sent as the X-Api-Token header.
TXLINE_API_TOKEN=

# Serverless tuning: the persistent-server autosync loop + SSE live stream can't
# run on serverless (Vercel) — set both "off" there and let /api/cron/sync keep
# data fresh. Leave unset (on) for a local or persistent-server deploy.
TXLINE_AUTOSYNC=
TXLINE_SSE=
