// Golazo Markets — Postgres application/index layer (Prisma).
//
// Source-of-truth split: the Solana devnet program owns escrow balances,
// positions, settlement and claims. Postgres mirrors that on-chain state for
// fast reads and powers every app screen (markets, receipts, leagues, history).
// Every on-chain transaction is written to `Transaction` with its signature,
// wallet, market and parsed metadata.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MarketStatus {
  OPEN
  LOCKED
  LIVE
  SETTLING
  SETTLED
  VOID
  REFUNDED
}

enum Side {
  YES
  NO
}

enum TxKind {
  FAUCET
  INIT_MARKET
  STAKE
  POST_ROOT
  SETTLE
  CLAIM
  REFUND
}

enum TxStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum PickResult {
  PENDING
  WON
  LOST
  VOID
}

model User {
  id          String   @id @default(cuid())
  handle      String   @unique
  displayName String?
  // Ghost mode (PRD §6.3): play without signup. A ghost user is keyed by an
  // anonymous device/session id and can later convert to a real account,
  // carrying its pick history over.
  isGhost     Boolean  @default(false)
  anonId      String?  @unique
  convertedAt DateTime?
  createdAt   DateTime @default(now())

  wallets        Wallet[]
  ownedLeagues   PrivateLeague[] @relation("LeagueOwner")
  leagueMembers  LeagueMember[]
  predictions    Prediction[]
}

model Wallet {
  id        String   @id @default(cuid())
  address   String   @unique
  cluster   String   @default("devnet")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  positions    MarketPosition[]
  transactions Transaction[]
}

model Match {
  id          String   @id // TxLINE fixture id (e.g. "WC-A-BRA-ARG")
  competition String?
  round       String?
  homeTeam    String
  awayTeam    String
  // Display meta mirrored from the TxLINE fixture (teams/branding).
  homeTicker  String?
  awayTicker  String?
  homeFlag    String?
  awayFlag    String?
  homeColor   String?
  awayColor   String?
  kickoff     DateTime
  lockAt      DateTime?
  status      String   @default("NOT_STARTED")
  minute      Int?
  homeScore   Int?
  awayScore   Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  markets      Market[]
  txlineEvents TxlineEvent[]
  predictions  Prediction[]
}

model Market {
  id           String       @id @default(cuid())
  match        Match        @relation(fields: [matchId], references: [id])
  matchId      String
  // The on-chain market_id, also the TxLINE stat key (e.g. "winner").
  marketId     String
  statKey      String
  question     String
  status       MarketStatus @default(OPEN)
  lockTs       DateTime
  yesTotal     BigInt       @default(0)
  noTotal      BigInt       @default(0)
  winningSide  Side?
  // On-chain addresses (PDAs) for verification + receipts.
  poolPda      String?
  vaultPda     String?
  mint         String?
  createdAt    DateTime     @default(now())

  positions    MarketPosition[]
  settlement   Settlement?
  proofReceipts ProofReceipt[]
  transactions Transaction[]

  @@unique([matchId, marketId])
}

model MarketPosition {
  id            String   @id @default(cuid())
  market        Market   @relation(fields: [marketId], references: [id])
  marketId      String
  wallet        Wallet   @relation(fields: [walletAddress], references: [address])
  walletAddress String
  side          Side
  amount        BigInt   @default(0)
  claimed       Boolean  @default(false)
  positionPda   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([marketId, walletAddress])
}

// Append-only TxLINE live log (PRD §10.3 — keep the full trail, not just latest).
// `seq` is monotonic per match; current state is derived from the latest event.
model TxlineEvent {
  id        String   @id @default(cuid())
  match     Match    @relation(fields: [matchId], references: [id])
  matchId   String
  seq       Int      @default(0)
  type      String // "kickoff" | "goal" | "ht" | "second_half" | "ft" | "state" | "void"
  state     String?
  minute    Int?
  homeScore Int?
  awayScore Int?
  payload   Json
  createdAt DateTime @default(now())

  @@unique([matchId, seq])
  @@index([matchId])
}

model Settlement {
  id           String   @id @default(cuid())
  market       Market   @relation(fields: [marketId], references: [id])
  marketId     String   @unique
  winningSide  Side?
  claimedValue Int
  merkleRoot   String
  proof        Json
  settleTx     String?
  voided       Boolean  @default(false)
  settledAt    DateTime @default(now())
}

model ProofReceipt {
  id             String   @id @default(cuid())
  market         Market   @relation(fields: [marketId], references: [id])
  marketId       String
  walletAddress  String
  prediction     Side
  result         String? // resolved outcome label or "VOID"
  verified       Boolean  @default(false)
  escrowAddress  String?
  settlementTx   String?
  claimTx        String?
  createdAt      DateTime @default(now())

  @@unique([marketId, walletAddress])
  @@index([marketId])
  @@index([walletAddress])
}

model Transaction {
  id            String   @id @default(cuid())
  signature     String   @unique
  wallet        Wallet?  @relation(fields: [walletAddress], references: [address])
  walletAddress String?
  market        Market?  @relation(fields: [marketId], references: [id])
  marketId      String?
  kind          TxKind
  status        TxStatus @default(CONFIRMED)
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([walletAddress])
  @@index([marketId])
}

// A free-to-play pick (Golazo Picks). Decoupled from the on-chain Market model:
// references the fixture + market type + chosen option directly. Settlement
// (P2-11) writes status/points/proof from the deterministic resolver.
model Prediction {
  id              String     @id @default(cuid())
  user            User       @relation(fields: [userId], references: [id])
  userId          String
  match           Match      @relation(fields: [matchId], references: [id])
  matchId         String
  marketId        String     // "winner" | "totals" | "btts" | "chaos"
  optionId        String     // chosen option (team ticker / "over" / "yes" / ...)
  predictionLabel String
  status          PickResult @default(PENDING)
  points          Int        @default(0)
  proofRef        String?    // TxLINE payload reference recorded at settlement
  settledAt       DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  @@unique([userId, matchId, marketId]) // one pick per market per user
  @@index([userId])
  @@index([matchId])
}

model PrivateLeague {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  owner       User?    @relation("LeagueOwner", fields: [ownerUserId], references: [id])
  ownerUserId String?
  createdAt   DateTime @default(now())

  members LeagueMember[]
}

model LeagueMember {
  id        String        @id @default(cuid())
  league    PrivateLeague @relation(fields: [leagueId], references: [id])
  leagueId  String
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  joinedAt  DateTime      @default(now())

  @@unique([leagueId, userId])
}
