# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local
.env.local
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated artifacts
snapshot_*.csv
holder-snapshot.csv
.playwright-mcp/

# compiled scripts (TS in scripts/ may emit JS / declaration files)
scripts/*.js
scripts/*.d.ts
scripts/*.js.map

# claude code — local, per-developer settings (a shared settings.json is fine)
.claude/settings.local.json

# internal docs — kept local, not pushed to the public repo
ADMIN_GUIDE.md
GOLAZO.md
GOLAZO_PROMPTS.md
DEPLOY.md

# internal planning — feature designs / roadmap, local only, never pushed
/planning/

# token launch scratchpad — local working file with mint addresses, never pushed
golazo-launch.txt

# downloaded launch flag assets — local only, regenerable, never pushed
/flags/

# Visual brainstorming companion
.superpowers/
